# Copy to .env.local and fill in real values. Never commit .env.local.

# Postgres connection string (Vercel Postgres / Neon / any Postgres works).
# Vercel Postgres: Project -> Storage -> Create Database -> Postgres, then
# copy the "DATABASE_URL" (or "POSTGRES_URL") value it generates for you.
DATABASE_URL=postgres://user:password@host:5432/dbname

# Random 32+ byte secret used to sign admin session cookies. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
